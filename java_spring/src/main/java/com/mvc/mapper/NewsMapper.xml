<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mvc.mapper.NewsMapper">

    <insert id="add" parameterType="com.mvc.entity.News">
        insert into news(title,content,createtime,opername) values(#{title},#{content},#{createtime},#{opername})
    </insert>

    <update id="update" parameterType="com.mvc.entity.News">
        update news set title = #{title},content = #{content},opername = #{opername} where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from news where id = #{id}
    </delete>

    <select id="getById" parameterType="java.lang.Integer" resultType="com.mvc.entity.News">
        select * from news where id = #{id}
    </select>

</mapper>