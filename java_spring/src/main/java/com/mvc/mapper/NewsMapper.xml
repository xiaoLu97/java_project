<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mvc.mapper.NewsMapper">

    <insert id="add" parameterType="com.mvc.entity.News">
        insert into news(title,content,createtime,opername) values(#{title},#{content},#{createtime},#{opername})
    </insert>

</mapper>